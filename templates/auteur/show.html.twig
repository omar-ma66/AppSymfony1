{% extends 'base.html.twig' %}

{% block title %}Auteur{% endblock %}

{% block body %}
    <h1>Auteur</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ auteur.id }}</td>
            </tr>
            <tr>
                <th>Nom:</th>
                <td>{{ auteur.firstName }}</td>
            </tr>
            <tr>
                <th>Prenom:</th>
                <td>{{ auteur.lastName }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_auteur_index') }}">Retour aux auteurs</a>

    <a href="{{ path('app_auteur_edit', {'id': auteur.id}) }}">Modifier</a>

    {{ include('auteur/_delete_form.html.twig') }}
{% endblock %}
